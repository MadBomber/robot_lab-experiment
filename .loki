# frozen_string_literal: true
# robot_lab-experiment — experimental self-building RobotLab pipeline. A Rails
# app, not a packaged gem, so it does not import repo_dev.loki's
# build/install/release tasks (mirrors sqa_project/sqa-rails/.loki, the only
# other non-gem app in this asgard ecosystem).

class Tasks
  header "robot_lab-experiment — self-building RobotLab pipeline (Rails app)"

  # Minimum line coverage (%) required by `asgard quality`. Change it here to
  # move the gate; the summary always shows this threshold and the actual value.
  COVERAGE_THRESHOLD = 90

  desc "Install dependencies and prepare the database"
  def setup
    sh "bin/setup"
  end

  desc "Start the Rails dev server (Puma + Tailwind watcher)"
  def server
    sh "bin/dev"
  end

  desc "Open the Rails console"
  def console
    sh "bin/rails console"
  end

  desc "Run database migrations"
  def migrate
    sh "bin/rails db:migrate"
  end

  desc "Run the test suite"
  def test
    sh "bin/rails test"
  end

  desc "Check code style with RuboCop"
  def rubocop
    sh "bin/rubocop"
  end

  desc "Auto-correct RuboCop offenses"
  def rubocop_fix
    sh "bin/rubocop -a"
  end

  desc "Check code smells with Reek (fails only on new or worsened files)"
  def reek
    current  = reek_scan
    baseline = load_reek_baseline

    new_files = current.reject { |f, _| baseline.key?(f) }
    worsened  = current.select { |f, c| baseline.key?(f) && c > baseline[f] }
    improved  = baseline.count { |f, c| current.key?(f) && current[f] < c }
    cleaned   = baseline.keys - current.keys

    total_current  = current.values.sum
    total_baseline = baseline.values.sum

    puts "\nReek: #{total_current} warning(s) across #{current.size} file(s) " \
         "(#{total_baseline} grandfathered across #{baseline.size} file(s))."
    puts "  #{cleaned.size} file(s) fully clean — run `asgard reek_baseline` to prune." unless cleaned.empty?
    puts "  #{improved} file(s) improved — run `asgard reek_baseline` to ratchet down." unless improved.zero?

    problems = new_files.map { |f, c| format("NEW      %3d warning(s): %s", c, f) } +
               worsened.map  { |f, c| format("WORSENED %3d -> %3d: %s", baseline[f], c, f) }

    if problems.empty?
      puts "Reek quality gate passed (no new or worsened files)."
    else
      puts "\nReek quality gate FAILED:"
      problems.each { |p| puts "  #{p}" }
      abort "\nReek: #{problems.size} file(s) regressed. Fix smells, or `asgard reek_baseline` if intentional."
    end
  end

  desc "Regenerate the Reek baseline (grandfathers current smell counts per file)"
  def reek_baseline
    require "fileutils"
    FileUtils.mkdir_p(".quality")
    warnings = reek_scan
    body = warnings.sort_by { |f, _| f }.map { |f, c| "#{c}\t#{f}" }.join("\n")
    File.write(".quality/reek_baseline.txt", body.empty? ? "" : "#{body}\n")
    puts "Wrote #{warnings.size} file(s) with smells to .quality/reek_baseline.txt"
  end

  desc "Run all quality gates: tests + RuboCop + Flog + Flay + Reek + Rails Best Practices + security audits"
  def quality
    gates = [
      # COVERAGE=1 runs the suite single-process under SimpleCov so the coverage
      # gate below has fresh data; exit status still reflects tests only.
      ["Tests", "env COVERAGE=1 bin/rails test"],
      ["RuboCop", "bin/rubocop"],
      ["Flog Complexity", "bin/rails flog_check"],
      ["Flay Duplication", "bin/rails flay_check"],
      ["Reek Smells", -> { reek_gate }],
      ["Rails Best Practices", "bundle exec rails_best_practices ."],
      ["Bundler Audit", "bin/bundler-audit"],
      ["Importmap Audit", "bin/importmap audit"],
      ["Brakeman", "bin/brakeman --quiet --no-pager --exit-on-warn --exit-on-error"]
    ]

    results = gates.map do |label, command|
      puts "\n#{"=" * 60}"
      puts "Quality Gate: #{label}"
      puts "=" * 60
      ok = command.respond_to?(:call) ? command.call : system(command)
      [label, ok ? :pass : :fail]
    end

    # Show coverage as its own pass/fail line right below Tests.
    tests_idx = results.index { |label, _| label == "Tests" } || -1
    results.insert(tests_idx + 1, coverage_gate)

    print_quality_summary(results)
  end

  no_commands do
    # Coverage summary line for `asgard quality`, e.g.
    #   [PASS] code coverage > 90% @ 96.98%
    # Reads SimpleCov's last-run line coverage (written by the COVERAGE=1 Tests
    # gate) and passes when it meets COVERAGE_THRESHOLD.
    def coverage_gate
      pct = line_coverage
      label = if pct
                format("code coverage > %d%% @ %.2f%%", COVERAGE_THRESHOLD, pct)
              else
                "code coverage > #{COVERAGE_THRESHOLD}% (no coverage data)"
              end
      [label, pct && pct >= COVERAGE_THRESHOLD ? :pass : :fail]
    end

    # SimpleCov's last-run line-coverage percentage, or nil if unavailable.
    def line_coverage
      require "json"
      path = "coverage/.last_run.json"
      return nil unless File.exist?(path)

      JSON.parse(File.read(path)).dig("result", "line")
    rescue StandardError
      nil
    end

    # Nearest ancestor (including cwd) containing +name+, or nil. Finds the
    # shared robot_lab_project/.reek.yml the same way import_up locates .loki
    # files, so this repo needs no .reek.yml of its own.
    def find_up(name, from: Dir.pwd)
      dir = Pathname.new(from).expand_path
      loop do
        candidate = dir.join(name)
        return candidate.to_s if candidate.exist?
        break if dir.root?

        dir = dir.parent
      end
      nil
    end

    # Smell count per file (only files with >0 smells). Scans app/**/*.rb --
    # this is a Rails app, not a gem, so its source lives under app/, not lib/.
    def reek_scan
      require "reek"
      require "reek/configuration/app_configuration"
      config_file = find_up(".reek.yml")
      config = config_file ? Reek::Configuration::AppConfiguration.from_path(Pathname.new(config_file)) : nil
      Dir.glob("app/**/*.rb").each_with_object({}) do |f, acc|
        count = Reek::Examiner.new(File.read(f), configuration: config).smells.size
        acc[f] = count if count.positive?
      end
    end

    # Grandfathered smell counts from .quality/reek_baseline.txt ("count\tfile").
    def load_reek_baseline
      path = File.join(".quality", "reek_baseline.txt")
      return {} unless File.exist?(path)

      File.readlines(path).each_with_object({}) do |line, acc|
        count, file = line.strip.split("\t", 2)
        acc[file] = count.to_i if file && !file.empty?
      end
    end

    # Non-aborting gate for the quality summary: true when no new/worsened files.
    def reek_gate
      current  = reek_scan
      baseline = load_reek_baseline
      new_files = current.reject { |f, _| baseline.key?(f) }
      worsened  = current.select { |f, c| baseline.key?(f) && c > baseline[f] }
      (new_files.empty? && worsened.empty?).tap do |ok|
        report = ok ? "Reek quality gate passed.\n" : reek_failure_report(new_files, worsened, baseline)
        File.write("reek_output.txt", report)
      end
    end

    def reek_failure_report(new_files, worsened, baseline)
      lines  = ["Reek quality gate FAILED:\n"]
      lines += new_files.map { |f, c| format("  NEW      %3d warning(s): %s\n", c, f) }
      lines += worsened.map  { |f, c| format("  WORSENED %3d -> %3d: %s\n", baseline[f], c, f) }
      lines.join
    end

    def print_quality_summary(results)
      green = ->(s) { "\e[32m#{s}\e[0m" }
      red   = ->(s) { "\e[31m#{s}\e[0m" }
      width = results.map { |label, _| label.length }.max

      puts "\n#{"=" * 60}"
      puts "Quality Gate Summary"
      puts "=" * 60
      results.each do |label, status|
        badge = status == :pass ? green.call("PASS") : red.call("FAIL")
        puts "  [#{badge}] #{label.ljust(width)}"
      end
      puts "-" * 60

      passed = results.count { |_, s| s == :pass }
      failed = results.count { |_, s| s == :fail }
      tally  = "#{passed} passed, #{failed} failed"
      puts "  #{failed.zero? ? green.call(tally) : red.call(tally)}"
      puts "=" * 60

      abort "\n#{red.call("Quality gate failed.")}" unless failed.zero?
      puts "\n#{green.call("All quality gates passed.")}"
    end
  end
end
