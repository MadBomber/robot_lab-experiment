<div class="w-full max-w-4xl">
  <div id="task-header">
    <p class="text-sm text-gray-500 mb-1"><%= link_to project.name, project %></p>
    <h1 class="text-2xl font-bold mb-1"><%= task.title %></h1>
    <p class="text-sm text-gray-500 mb-4 flex items-center gap-2 flex-wrap">
      <span>
        status: <%= task.status %>
        &middot; runs: <%= task.workflow_run_count %>/<%= Task::MAX_WORKFLOW_RUNS %>
        <% if task.blocked? %>
          &middot; <span class="text-red-600 font-medium">blocked (<%= task.blocked_reason %>)</span>
          <% if task.blocked_detail.present? %>
            <div class="text-xs text-gray-600 mt-1">
              <span><%= task.blocked_detail %></span>
              <% if task.blocked_run_id.present? %>
                &middot; <%= link_to "run ##{task.blocked_run_id}", project_task_agent_run_path(task.project, task, AgentRun.find_by(id: task.blocked_run_id)), class: "text-blue-600 hover:underline" %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </span>
      <%= form_with url: update_status_project_task_path(project, task), method: :patch, class: "inline-flex items-center gap-1" do |f| %>
        <%= f.select :status, Task.statuses.keys, { selected: task.status }, class: "text-xs border rounded" %>
        <%= f.submit "Set status", class: "text-xs bg-gray-200 hover:bg-gray-300 px-2 py-1 rounded cursor-pointer" %>
      <% end %>
    </p>

    <%= render "tasks/agent_status", running: task.running_agent_run.present?, task: %>

    <div class="mb-6 space-x-2">
      <% task.runnable_agent_types.each do |agent_type| %>
        <%= button_to "Run #{agent_type}", project_task_agent_runs_path(project, task),
              params: { agent_type: agent_type }, class: "bg-blue-600 text-white px-4 py-2 rounded" %>
      <% end %>
      <% if task.running_agent_run.present? %>
        <%= button_to "Stop", stop_project_task_path(project, task), method: :post,
              class: "bg-red-600 text-white px-4 py-2 rounded" %>
        <%= button_to "Pause", pause_project_task_path(project, task), method: :post,
              class: "bg-yellow-600 text-white px-4 py-2 rounded" %>
      <% end %>
      <% if task.blocked? %>
        <%= button_to "Resume", unblock_project_task_path(project, task), method: :post,
              class: "bg-amber-600 text-white px-4 py-2 rounded" %>
      <% end %>
      <% unless task.completed? || task.blocked_reason == "abandoned" %>
        <%= button_to "Abandon", abandon_project_task_path(project, task), method: :post,
              data: { turbo_confirm: "Give up on this task and stop all agents?" },
              class: "bg-gray-600 text-white px-4 py-2 rounded" %>
      <% end %>
    </div>

    <% unless task.completed? %>
      <details class="mb-6" <%= "open" if task.pending_guidance.present? %>>
        <summary class="cursor-pointer text-sm text-blue-600">Give the agents guidance</summary>
        <% if task.pending_guidance.present? %>
          <p class="text-xs text-gray-500 mt-2">Queued for the next run:
            <span class="italic"><%= task.pending_guidance %></span></p>
        <% end %>
        <%= form_with url: guide_project_task_path(project, task), method: :post, class: "mt-2" do |f| %>
          <%= f.text_area :guidance, rows: 3, placeholder: "e.g. use the Playwright MCP server, not Selenium",
                class: "w-full border rounded p-2 text-sm" %>
          <%= f.submit "Send guidance", class: "mt-1 bg-blue-600 text-white px-3 py-1 rounded text-sm cursor-pointer" %>
        <% end %>
        <p class="text-xs text-gray-400 mt-1">Applied on the next run. To redirect an in-flight run, Stop it first.</p>
      </details>
    <% end %>
  </div>
</div>
