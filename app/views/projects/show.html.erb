<div class="w-full max-w-2xl">
  <h1 class="text-2xl font-bold mb-1"><%= @project.name %></h1>
  <p class="text-gray-500 text-sm mb-4"><%= @project.effective_cwd %></p>

  <ul class="divide-y divide-gray-200 mb-6">
    <% @tasks.each do |task| %>
      <li class="py-3 flex items-center justify-between">
        <%= link_to task.title, [@project, task], class: "text-blue-600 hover:underline" %>
        <span class="text-xs uppercase text-gray-500"><%= task.status %></span>
      </li>
    <% end %>
  </ul>

  <div class="flex gap-2 mb-6">
    <%= link_to "Edit", edit_project_path(@project), class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded" %>
    <%= button_to "Delete project", project_path(@project), method: :delete,
          data: { turbo_confirm: "This will delete all tasks, worktrees, and archived docs for #{@project.name}.\n\nAre you sure?" },
          class: "inline-block bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded",
          form_class: "inline" %>
    <%= link_to "New task", new_project_task_path(@project), class: "inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded" %>
    <%= button_to "Run self-audit", project_audit_tasks_path(@project),
          class: "inline-block bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded ml-2", form_class: "inline" %>
  </div>

  <h2 class="text-lg font-semibold mb-2 mt-6">Open GitHub Issues</h2>
  <% if @open_issues.present? %>
    <ul class="divide-y divide-gray-200">
      <% @open_issues.each do |issue| %>
        <li class="py-3 flex items-center justify-between">
          <%= link_to "##{issue.number} #{issue.title}", issue.url, target: "_blank", rel: "noopener",
                class: "text-blue-600 hover:underline" %>
          <%= link_to "Create task", new_project_task_path(@project, from_issue: issue.number),
                class: "text-sm bg-gray-100 px-3 py-1 rounded" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-gray-500">No open issues.</p>
  <% end %>
</div>
