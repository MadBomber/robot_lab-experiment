<div class="w-full max-w-2xl">
  <h1 class="text-2xl font-bold mb-4">Projects</h1>

  <ul class="divide-y divide-gray-200 mb-6">
    <% @projects.each do |project| %>
      <li class="py-3 flex items-center justify-between">
        <%= link_to project.name, project, class: "text-blue-600 hover:underline" %>
        <span class="text-gray-500 text-sm mr-4"><%= project.repo_folder_path %></span>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_project_path(project), class: "text-blue-600 hover:underline text-sm" %>
          <%= button_to "Delete", project_path(project), method: :delete,
                data: { turbo_confirm: "Delete this project and all associated tasks/worktrees?" },
                class: "text-red-600 hover:underline text-sm", form_class: "inline" %>
        </div>
      </li>
    <% end %>
  </ul>

  <%= link_to "New project", new_project_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded" %>
</div>
